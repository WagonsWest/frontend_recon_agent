# Local configuration example — copy to settings.local.yaml and fill in your values
# Only include settings you want to override from settings.yaml

target:
  url: "https://your-website.com/login"
  dashboard_url: "https://your-website.com/dashboard"  # URL after login (leave empty to auto-detect)

task:
  goal: "Sign up, enter the product, and understand the main workflows."
  goal_keywords: []
  allow_registration_flows: true
  allow_login_flows: true
  captcha_policy: "pause_and_report"
  human_assistance_allowed: true
  use_site_memory: true
  validate_action_outcomes: true
  reobserve_on_state_change: true
  use_vision_on_state_change: true
  max_reobservations_per_run: 30
  profile_name: "Test User"
  profile_email: "test@example.com"
  profile_password: "TestPassword123!"
  profile_company: "Example Inc"

login:
  mode: "login"  # public | login | register | auto
  username: "your_username"
  password: "your_password"
  # register_url: "https://your-website.com/signup"
  # register_link_selector: "a:has-text('Sign up')"
  # Uncomment and modify if defaults don't match your site:
  # username_selector: "input[type='text'], input[name='username']"
  # password_selector: "input[type='password']"
  # submit_selector: "button[type='submit'], button:has-text('Login')"
  # registration_email_selector: "input[type='email']"
  # registration_password_selector: "input[name='password']"
  # registration_submit_selector: "button[type='submit']"
  # verification_code_selector: "input[autocomplete='one-time-code'], input[name*='code']"
  # verification_submit_selector: "button:has-text('Verify'), button:has-text('Continue')"

# --- Optional overrides (defaults in settings.yaml are usually fine) ---

