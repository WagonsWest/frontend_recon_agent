# Frontend Mimic Environment Variables
# Copy this to .env and fill in your values

# Website credentials (alternative to settings.local.yaml)
MIMIC_USERNAME=your_username
MIMIC_PASSWORD=your_password

# AI API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Vision provider overrides
VISION_API_KEY=
VISION_API_BASE_URL=
